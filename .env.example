# Copy to .env and fill in real values before running in LIVE mode.
# NEVER commit .env to version control.

# ── Wallet / Auth ────────────────────────────────────────────────────────────
POLY_PRIVATE_KEY=your_eoa_private_key_hex_without_0x_prefix
POLY_FUNDER_ADDRESS=0xYourProxyWalletFunderAddress

# ── Polymarket CLOB API credentials ─────────────────────────────────────────
# Generate via: https://clob.polymarket.com (or py_clob_client.create_or_derive_api_creds)
POLY_API_KEY=your_api_key
POLY_API_SECRET=your_api_secret
POLY_API_PASSPHRASE=your_api_passphrase

# ── Database ─────────────────────────────────────────────────────────────────
DB_BACKEND=sqlite                       # "sqlite" | "postgresql"
SQLITE_PATH=data/trades.db
# POSTGRES_DSN=postgresql://user:pass@localhost/polymarket

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
